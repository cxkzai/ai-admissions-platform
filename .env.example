# ===== AI-Admissions Platform 环境变量模板 =====
# 复制本文件为 .env 并填入真实值（.env 不会入仓）

# ============ 应用基础 ============
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-string
APP_NAME=ai-admissions-platform
APP_VERSION=0.1.0

# ============ 后端 API ============
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============ 数据库 ============
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/edu_admissions
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/edu_admissions

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ LLM 提供商 ============
# ▶ 主力：DeepSeek（中文好、价格便宜 ¥1/M token、面试官有代入感）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ☐ 可选：Anthropic Claude（演示效果最佳，但成本高）
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ☐ 可选：OpenAI（GPT-4o 系列）
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# 默认 LLM 引擎：deepseek / claude / openai
LLM_DEFAULT_ENGINE=deepseek

# ============ Embedding ============
# 演示推荐用 OpenAI text-embedding-3-small（高性价比）
# 生产可选 bge-m3（中文优化、本地部署、无 API 成本）
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# OPENAI_API_KEY 已在上方定义，Embedding 复用

# DeepSeek 也提供 Embedding API（如果用 DeepSeek 一站式）
# DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# ============ 向量库 ============
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_data

# ============ IM Webhook（演示用 Mock 即可） ============
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
WECOM_WEBHOOK_URL=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ============ 日志 / 监控 ============
LOG_LEVEL=INFO
SENTRY_DSN=

# ============ 前端 ============
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=AI-Admissions Platform